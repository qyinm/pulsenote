{
  "name": "pulsenote",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --dir apps/site dev",
    "dev:site": "pnpm --dir apps/site dev",
    "build": "pnpm --dir apps/site build",
    "build:site": "pnpm --dir apps/site build",
    "lint": "pnpm --dir apps/site lint",
    "lint:site": "pnpm --dir apps/site lint",
    "typecheck:site": "pnpm --dir apps/site exec tsc --noEmit"
  }
}
