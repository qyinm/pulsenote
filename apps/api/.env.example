APP_NAME=pulsenote-api
NODE_ENV=production
AUTO_RUN_MIGRATIONS=true
HOST=0.0.0.0
PORT=8787
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<database>
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://api.pulsenotes.xyz
BETTER_AUTH_COOKIE_DOMAIN=.pulsenotes.xyz
GITHUB_APP_ID=1234567
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-github-app-private-key\n-----END PRIVATE KEY-----"
GITHUB_APP_SLUG=pulsenote
TRUSTED_ORIGINS=https://app.pulsenotes.xyz
