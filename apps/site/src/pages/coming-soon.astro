---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PulseNote | Hosted access coming soon" description="PulseNote hosted access is still being prepared around release review, approval, and publish-pack export.">
  <div class="page-shell">
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href="/" aria-label="PulseNote home">
          <img src="/brand-mark.svg" alt="" />
          <span>
            PulseNote
            <small>Release communication system</small>
          </span>
        </a>

        <div class="header-actions">
          <a class="button-secondary" href="/">Back to site</a>
        </div>
      </div>
    </header>

    <main class="hero">
      <div class="container hero-grid hero-grid-single">
        <section class="hero-copy">
          <span class="eyebrow">Hosted access</span>
          <h1>The review workspace is still being prepared.</h1>
          <p>
            PulseNote’s hosted product opens around release review rather than a blank writing surface. The first
            experience is being shaped around draft inspection, claim checks, human approval, and publish-pack export.
          </p>
          <div class="hero-actions">
            <a class="button" href="/">Return to landing page</a>
            <a class="button-secondary" href="mailto:biz@pulsenotes.xyz">Email biz@pulsenotes.xyz</a>
          </div>
        </section>

        <section class="panel">
          <p class="panel-kicker">What opens first</p>
          <h2>Hosted surface priorities</h2>
          <div class="faq-stack compact-stack">
            <article class="faq-item compact-card">
              <h3>Release review workspace</h3>
              <p>The draft and its source evidence stay visible in the same place during review.</p>
            </article>
            <article class="faq-item compact-card">
              <h3>Approval visibility</h3>
              <p>Reviewer comments, rationale, and sign-off stay attached before export.</p>
            </article>
            <article class="faq-item compact-card">
              <h3>Publish-pack handoff</h3>
              <p>Approved notes, support brief, and references leave together as one controlled export.</p>
            </article>
          </div>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
